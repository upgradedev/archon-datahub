{
  "$schema": "https://json.schemastore.org/c8rc.json",
  "all": true,
  "src": ["src"],
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.d.ts",
    "src/types.ts",
    "src/server.ts",
    "src/config/env.ts",
    "src/datahub/mcp-client-live.ts"
  ],
  "reporter": ["text", "lcov"],
  "report-dir": "coverage",
  "check-coverage": true,
  "lines": 80,
  "functions": 80,
  "branches": 80,
  "statements": 80
}
